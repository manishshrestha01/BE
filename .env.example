# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub Configuration (for fetching notes from GitHub repo)
VITE_GITHUB_TOKEN=your_github_token

# ==============================
# Server-side IndexNow settings
# ==============================
# Do NOT prefix these with VITE_. Keep them on the server only.
SITE_URL=https://www.manishshrestha012.com.np
INDEXNOW_KEY=your_indexnow_key
INDEXNOW_ADMIN_TOKEN=your_strong_admin_token
# Optional (defaults to ${SITE_URL}/${INDEXNOW_KEY}.txt)
INDEXNOW_KEY_LOCATION=https://www.manishshrestha012.com.np/your_indexnow_key.txt
# Optional override for sitemap source
SITEMAP_URL=https://www.manishshrestha012.com.np/sitemap.xml
# Optional override used by scripts/generate-blog-static.js
INDEXNOW_BLOG_EVENT_ENDPOINT=https://www.manishshrestha012.com.np/api/indexnow/blog-event

# ==============================
# Server-side auth gate toggle
# ==============================
# Service role key (server only) used by /api/auth-gate to persist login mode in Supabase.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Dedicated token for toggling login mode from admin UI (falls back to INDEXNOW_ADMIN_TOKEN if omitted).
AUTH_TOGGLE_ADMIN_TOKEN=your_strong_auth_toggle_token
# Optional storage location overrides
AUTH_TOGGLE_TABLE=site_settings
AUTH_TOGGLE_KEY=require_login
# Optional default when no row exists (true keeps login required)
AUTH_TOGGLE_DEFAULT_REQUIRE_LOGIN=true

# ==================================
# Server-side PDF download toggle
# ==================================
# Token for toggling PDF.js download visibility from admin UI
# (falls back to AUTH_TOGGLE_ADMIN_TOKEN, then INDEXNOW_ADMIN_TOKEN if omitted).
PDF_DOWNLOAD_TOGGLE_ADMIN_TOKEN=your_strong_pdf_toggle_token
# Optional storage location overrides
PDF_DOWNLOAD_TOGGLE_TABLE=site_settings
PDF_DOWNLOAD_TOGGLE_KEY=pdf_download_enabled
# Optional default when no row exists (true shows download button)
PDF_DOWNLOAD_DEFAULT_ENABLED=true

# ==================================
# Server-side support reply backend
# ==================================
# Admin token required by POST /api/support/reply
# (falls back to AUTH_TOGGLE_ADMIN_TOKEN, then INDEXNOW_ADMIN_TOKEN if omitted).
SUPPORT_REPLY_ADMIN_TOKEN=your_strong_support_reply_token

# Resend API key for sending support replies to user emails.
RESEND_API_KEY=your_resend_api_key

# Verified sender identity in Resend (example: "StudyMate Support <support@yourdomain.com>")
SUPPORT_EMAIL_FROM=StudyMate Support <support@yourdomain.com>

# Optional reply-to mailbox shown to users when they click Reply in email clients.
SUPPORT_EMAIL_REPLY_TO=support@yourdomain.com

# Optional defaults for table names and subject prefix.
SUPPORT_MESSAGES_TABLE=support_messages
SUPPORT_REPLIES_TABLE=support_replies
SUPPORT_EMAIL_SUBJECT_PREFIX=StudyMate Support
