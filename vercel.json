{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "manishshrestha012.com.np" }
      ],
      "destination": "https://www.manishshrestha012.com.np/:path*",
      "permanent": true
    }
  ],
