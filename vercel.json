    {
      "source": "/((?!api(?:/|$)|blog(?:/|$)|college(?:/|$)|colleges(?:/|$)|about(?:/|$)|contact(?:/|$)|privacy-policy(?:/|$)|terms(?:/|$)|terms-of-service(?:/|$)|disclaimer(?:/|$)|favicon-48\\.png|logo-512\\.png|manifest\\.json|robots\\.txt|sitemap\\.xml|css(?:/|$)|assets(?:/|$)|_next(?:/|$)|.*\\.[^/]+$).*)",
